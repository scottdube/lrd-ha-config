# Secrets and sensitive files
secrets.yaml
known_devices.yaml

# HA runtime files
home-assistant.log
home-assistant.log.fault
.HA_VERSION
.storage/
.cloud/
.cache/

# Temporary files
*.tmp
*.bak

# Python
__pycache__/
*.pyc

# Node
node_modules/

# Custom components (large, reinstallable)
# Comment out if you want to track these
custom_components/

# Database files
*.db
*.db-shm
*.db-wal

# Pool runtime data — gitignored, lives at /config on the NUC.
pool_temp_log.csv      # v1 logger output (deprecated, retained during v2 phase 1)
pool_state_log.csv     # v2 logger output (logger-v2 spec)
pool_action_log.csv    # logger v2 phase 4 action log
.state_logger_token    # long-lived access token for state_logger.py

# Live rsync mirror of the NUC's pool_state_log.csv. Refreshed every 5 min
# by ~/Library/LaunchAgents/com.scottdube.ha.pool-log-rsync.plist.
# See pool/docs/rsync-setup.md.
pool/analysis/pool_state_log_live.csv

# Auditor output. As of 2026-07-07 (LRD ADR-036) the nightly JSON is
# published to the dedicated `audit` branch via plumbing in
# audit_yesterday.sh, NOT committed to main — so main stays human-only and
# the daily review reads it from the audit branch's raw URL. Ignored here so
# the Mac mini's main working tree stays clean. The JSONs tracked on main
# 2026-05-21..2026-07-06 stay in history (optional cleanup:
# `git rm --cached pool/audit/*.json` in a one-off commit to fully relocate).
pool/audit/

# Lock files
*.lock

# Zigbee database
zigbee.db
zigbee.db-shm
zigbee.db-wal
tts/
www/
.DS_Store

# Snagit source archives — extracted PNGs are the canonical record
*.snagx
**/_snagx-originals/
